{
	"compilerOptions": {
		"target": "ES2015",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"declaration": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"strict": true,
		"lib": ["ES2020", "DOM"],
		"noEmit": false,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
